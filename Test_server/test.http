### 37. Админ добавляет ОЧЕНЬ СТАРУЮ награду (старше 3 лет)
# Документ добавится в БД, но при подсчете баллов он должен игнорироваться
POST http://localhost:3000/admin/documents/manual
Content-Type: application/json
x-user-id: 1

{
  "user_id": 3,
  "document_name": "Грамота из глубокого прошлого",
  "category_id": 1,
  "points": 50,
  "comment": "Этот документ не должен учитываться в баллах",
  "received_date": "2019-03-20"
}

