# Database Configuration
DB_USER=postgres              # пользователь PostgreSQL (обычно postgres)
DB_HOST=localhost             # хост базы данных
DB_NAME=liga_abiturientov     # название базы данных
DB_PASSWORD=your_password     # ваш пароль от PostgreSQL
DB_PORT=5432                  # стандартный порт PostgreSQL

# Server Configuration
PORT=3000                     # порт для бэкенда

# SMTP Configuration (для восстановления пароля)
SMTP_PROVIDER=gmail
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# Frontend URL (для ссылок в письмах)
FRONTEND_URL=http://localhost:5173
